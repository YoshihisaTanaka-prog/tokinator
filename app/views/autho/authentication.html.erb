
<p><%= @msg %></p>
<table>
    <%= form_tag autho_path do %>
    <%= label_tag :email_or_level, "キーワード検索" %>
    <br>
    <%= search_field_tag :user, params['user'] %>
    <%= submit_tag "検索" %>
    <% end %>
</table>

<hr>

<table>
    <% if !@users.blank? then%>
        <tr>
            <th>Mail</th><th>　Id　</th><th>　Level　</th><th>　レベルダウン　</th><th>　レベルアップ　</th>
        </tr>
        <% @users.each do |obj| %>
        <tr>
            <td><%= obj.email %></td>
            <td align = "center" ><%= obj.id %></td>
            <td align = "center" ><%= obj.level %></td>
            
            <% if obj.level == 0 then %>
                <td align = "center" >x</td>
            <% else %>
                <td align = "center" ><%= link_to "-" ,autho_update_path( {:user_id => obj.id, :level => obj.level - 1 ,:user => params['user'] } ) %></td>
            <% end %>
            
            <td align = "center" ><%= link_to "+" ,autho_update_path( {:user_id => obj.id, :level => obj.level + 1 ,:user => params['user'] } ) %></td>
        </tr>
        <% end %>
    <% end %>
</table>

<hr>
<p><%= link_to "トップ", edits_path %></p>